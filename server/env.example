NGINX_MANAGER_DB_PATH=/var/lib/nginx-manager/manager.db
NGINX_MANAGER_UI_PATH=/opt/nginx-manager/current/ui/index.html

# Optional limits and liveness policy
NGINX_MANAGER_ONLINE_AFTER_SECONDS=90
NGINX_MANAGER_JOB_TTL_SECONDS=300
NGINX_MANAGER_MAX_JOB_TTL_SECONDS=86400
NGINX_MANAGER_SENSITIVE_JOB_TTL_SECONDS=900
NGINX_MANAGER_JOB_LEASE_SECONDS=60
NGINX_MANAGER_LATE_RESULT_GRACE_SECONDS=2592000
NGINX_MANAGER_JOB_RETENTION_SECONDS=2592000
NGINX_MANAGER_AUDIT_RETENTION_SECONDS=15552000
NGINX_MANAGER_METRIC_RETENTION_SECONDS=86400
NGINX_MANAGER_METRIC_RAW_RETENTION_SECONDS=7200
NGINX_MANAGER_MAX_LOG_SESSIONS=20
NGINX_MANAGER_MAX_LOG_SESSIONS_PER_USER=3
NGINX_MANAGER_LOG_SESSION_TTL_SECONDS=1800
NGINX_MANAGER_LOG_SESSION_BUFFER_BYTES=2097152
NGINX_MANAGER_MAX_PAYLOAD_BYTES=2097152
NGINX_MANAGER_MAX_UI_STATE_BYTES=16777216
NGINX_MANAGER_MAX_RESOURCE_BYTES=1048576
NGINX_MANAGER_SESSION_TTL_SECONDS=28800
NGINX_MANAGER_ENROLLMENT_PENDING_TTL_SECONDS=86400
NGINX_MANAGER_PASSWORD_ITERATIONS=310000
NGINX_MANAGER_LOGIN_WINDOW_SECONDS=300
NGINX_MANAGER_LOGIN_MAX_ATTEMPTS=8

# Optional LDAP / Active Directory login
NGINX_MANAGER_LDAP_ENABLED=false
NGINX_MANAGER_LDAP_URL=ldaps://ad.example.com:636
NGINX_MANAGER_LDAP_BASE_DN=DC=example,DC=com
NGINX_MANAGER_LDAP_BIND_DN=CN=nginx-manager,OU=Service Accounts,DC=example,DC=com
NGINX_MANAGER_LDAP_BIND_PASSWORD_FILE=/etc/nginx-manager/ldap-bind-password
NGINX_MANAGER_LDAP_USER_FILTER=(|(sAMAccountName={username})(userPrincipalName={username})(uid={username}))
NGINX_MANAGER_LDAP_GROUP_ATTRIBUTE=memberOf
NGINX_MANAGER_LDAP_ADMIN_GROUP=nginx-admin
NGINX_MANAGER_LDAP_OPERATOR_GROUP=nginx-operator
NGINX_MANAGER_LDAP_AUDITOR_GROUP=nginx-auditor
NGINX_MANAGER_LDAP_START_TLS=false
NGINX_MANAGER_LDAP_SESSION_RECHECK_SECONDS=300
# NGINX_MANAGER_LDAP_CA_FILE=/etc/nginx-manager/ldap-ca.crt
# OpenLDAP without memberOf:
# NGINX_MANAGER_LDAP_GROUP_SEARCH_BASE=OU=Groups,DC=example,DC=com
# NGINX_MANAGER_LDAP_GROUP_FILTER=(member={user_dn})
