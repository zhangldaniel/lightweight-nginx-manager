# Copy this server block into the local Nginx configuration and replace the
# server_name / ssl_certificate paths with certificates already managed by
# your local Nginx. The control plane itself listens only on 127.0.0.1:8443.

server {
    listen 443 ssl;
    server_name nginx-manager.example.com;

    ssl_certificate     /etc/nginx/ssl/nginx-manager.example.com.crt;
    ssl_certificate_key /etc/nginx/ssl/nginx-manager.example.com.key;

    client_max_body_size 8m;

    location / {
        proxy_pass http://127.0.0.1:8443;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_connect_timeout 5s;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}
